{% comment %}
  Snippet: Product Card
  Uso: {% render 'product-card', product: product, show_badge: true %}
  Parâmetros:
  - product: objeto do produto (obrigatório)
  - show_badge: exibir badge de promoção (opcional, default: true)
  - image_width: largura da imagem (opcional, default: 400)
{% endcomment %}

{%- assign largura = image_width | default: 400 -%}
{%- assign exibir_badge = true -%}
{%- if show_badge == false -%}
  {%- assign exibir_badge = false -%}
{%- endif -%}

<div class="product-card">
  <img
    src="{{ product.featured_image | image_url: width: largura }}"
    alt="{{ product.featured_image.alt | default: product.title }}"
  >
  <div class="text-box">
    <h3 class="product-card__titulo">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    <p class="product-card__preco">{{ product.price | money }}</p>

    {% if exibir_badge %}
      {% if product.compare_at_price > product.price %}
        {%- assign valor_economizado = product.compare_at_price | minus: product.price -%}
        {%- assign multiplicado_por_cem = valor_economizado | times: 100 -%}
        {%- assign com_desconto = multiplicado_por_cem | divided_by: product.compare_at_price | floor -%}
        <span class="badge-promocao">{{ com_desconto }}% OFF</span>
        <s class="preco-original">{{ product.compare_at_price | money }}</s>
      {% elsif product.available == false %}
        <span class="badge-esgotado">Esgotado</span>
      {% endif %}
    {% endif %}

    {% if product.available %}
      <button class="btn-carrinho">Adicionar ao carrinho</button>
    {% else %}
      <button class="btn-carrinho" disabled>Indisponível</button>
    {% endif %}
  </div>
</div>
<style>
  .product-card {
    border: 1px solid #eee;
    border-radius: 8px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: box-shadow 0.3s;
    background: #fff;
    position: relative;
  }
  .product-card:hover {
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
  }
  .product-card img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }

  .text-box {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .product-card__titulo a {
    text-decoration: none;
    color: #333;
  }
  .product-card__preco {
    font-weight: bold;
    color: #27ae60;
  }
  .preco-original {
    color: #999;
    font-size: 0.9em;
    margin-left: 5px;
  }
  .btn-carrinho {
    width: 100%;
    padding: 10px;
    background: #333;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    margin-top: auto;
  }
  .btn-carrinho:disabled {
    background: #ccc;
    cursor: not-allowed;
  }
  .badge-promocao,
  .badge-esgotado {
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: bold;
    color: white;
  }
  .badge-promocao {
    background: #e74c3c;
  }
  .badge-esgotado {
    background: #95a5a6;
  }
</style>
