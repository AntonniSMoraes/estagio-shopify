{% comment %}
  Exercício 2.1 — Liquid Básico
  Estagiário: Antonni Moraes
{% endcomment %}
{% schema %}
{
  "name": "Exercício Liquid Básico",
  "settings": [
    {
      "type": "text",
      "id": "titulo",
      "label": "Título da seção",
      "default": "Bem-vindo à nossa loja"
    },
    {
      "type": "richtext",
      "id": "descricao",
      "label": "Descrição",
      "default": "<p>Aqui você encontra os melhores produtos.</p>"
    },
    {
      "type": "range",
      "id": "quantidade_produtos",
      "label": "Quantidade de produtos para exibir",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grade" },
        { "value": "list", "label": "Lista" }
      ],
      "default": "grid"
    }
  ],
  "presets": [
    {
      "name": "Exercício Liquid Básico"
    }
  ]
}
{% endschema %}
<section class="exercicio-basico">
  {% comment %} Tarefa 1 {% endcomment %}
  <h2>{{ section.settings.titulo }}</h2>
  
  {% comment %} Tarefa 2 {% endcomment %}
  <div class="descricao">{{ section.settings.descricao }}</div>

  {% comment %} Tarefa 4 {% endcomment %}
  {% if section.settings.layout == 'grid' %}
    {% assign classe_layout = 'layout-grid' %}
  {% elsif section.settings.layout == 'list' %}
    {% assign classe_layout = 'layout-list' %}
  {% endif %}

  {% comment %} Tarefa 3 {% endcomment %}
  <div class="{{ classe_layout }}">
    {% for product in collections.all.products limit: section.settings.quantidade_produtos %}
      <div class="produto-item">
        <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title }}">
        <h3>{{ product.title }}</h3>
        <p class="preco">{{ product.price | money }}</p>
      </div>
    {% endfor %}
  </div>
</section>
<style>
  .exercicio-basico {
    {% comment %} Para que o grid funcionasse corretamente, foi necessário adicionar width ao container pai {% endcomment %}
    width: 100%; 
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .exercicio-basico h2 {
  }

  .exercicio-basico h2 {
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .exercicio-basico .descricao {
    text-align: center;
    color: #666;
    margin-bottom: 2rem;
  }

  /* Layout Grid */
  .layout-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
  }
  /* Layout Lista */
  .layout-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .produto-item {
    align-self: center;
    border: 1px solid #eee;
    border-radius: 8px;
    padding: 1rem;
    text-align: center;
  }
  .produto-item img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }
  .produto-item h3 {
    margin: 0.5rem 0 0.25rem;
    font-size: 1rem;
  }
  .produto-item .preco {
    color: #333;
    font-weight: bold;
  }
  /* Adicione seus estilos adicionais aqui */
</style>
